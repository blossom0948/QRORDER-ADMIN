rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function storePath(storeId) {
      return /databases/$(database)/documents/stores/$(storeId);
    }

    function qrPath(storeId, token) {
      return /databases/$(database)/documents/stores/$(storeId)/qrSessions/$(token);
    }

    function ownsStore(storeId) {
      return signedIn()
        && exists(storePath(storeId))
        && get(storePath(storeId)).data.ownerUid == request.auth.uid;
    }

    function validQr(storeId, token, tableNo) {
      return token is string
        && tableNo is string
        && exists(qrPath(storeId, token))
        && get(qrPath(storeId, token)).data.active == true
        && get(qrPath(storeId, token)).data.tableNo == tableNo
        && get(qrPath(storeId, token)).data.expiresAt > request.time;
    }

    match /stores/{storeId} {
      allow get: if true;
      allow list: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if ownsStore(storeId)
        && request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if ownsStore(storeId);

      match /menus/{menuId} {
        allow read: if true;
        allow create, update, delete: if ownsStore(storeId);
      }

      match /qrSessions/{token} {
        allow get: if ownsStore(storeId)
          || (resource.data.active == true && resource.data.expiresAt > request.time);
        allow list, create, update, delete: if ownsStore(storeId);
      }

      match /orders/{orderId} {
        allow create: if validQr(storeId, request.resource.data.qrToken, request.resource.data.tableNo)
          && request.resource.data.status == "pending"
          && request.resource.data.items is list
          && request.resource.data.items.size() > 0
          && request.resource.data.items.size() <= 30
          && request.resource.data.total >= 0;

        allow get: if ownsStore(storeId)
          || validQr(storeId, resource.data.qrToken, resource.data.tableNo);
        allow list: if ownsStore(storeId);
        allow update, delete: if ownsStore(storeId);
      }
    }
  }
}
